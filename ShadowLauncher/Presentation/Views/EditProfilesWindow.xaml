<Window x:Class="ShadowLauncher.Presentation.Views.EditProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShadowLauncher.Presentation.Converters"
        Title="Edit Profiles" Height="340" Width="380" MinHeight="220" MinWidth="300"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <DockPanel Grid.Row="0" Margin="0,-8,0,0">
                <TextBlock Text="Edit Profiles" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11"
                        Click="Close_Click" Style="{DynamicResource IconButton}" Foreground="#888"
                        HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True"/>
            </DockPanel>

            <!-- Scrollable profile list -->
            <ScrollViewer Grid.Row="1" Margin="0,8,0,6"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="&#x2715;" FontSize="10"
                                        Padding="6,4" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Command="{Binding DataContext.DeleteCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Id}"
                                        Style="{DynamicResource IconButton}"
                                        ToolTip="Delete profile"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center" Padding="4,3"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Add profile button -->
            <Button Grid.Row="2" Content="+ Add Profile" HorizontalAlignment="Left"
                    Padding="10,4" Margin="0,0,0,8"
                    Command="{Binding AddProfileCommand}"
                    ToolTip="Add a new profile"/>

            <!-- Validation error -->
            <TextBlock Grid.Row="3"
                       Text="{Binding ErrorText}"
                       Foreground="#E8A838" FontSize="11"
                       Margin="0,0,0,8"
                       Visibility="{Binding ErrorText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Save" Padding="16,6" FontWeight="Bold"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
