<Window x:Class="ShadowLauncher.Presentation.Views.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShadowLauncher.Presentation.Converters"
        Title="Add Server" Height="560" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Emulator Type -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Emulator:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding EmulatorTypes}"
                  SelectedItem="{Binding Emulator}" Margin="0,0,0,8"/>

        <!-- Server Name -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Server Name:*" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,8"/>

        <!-- Description -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,8"/>

        <!-- Server IP -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Server IP:*" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding Hostname, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,8"/>

        <!-- Server Port -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Server Port:*" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,8"/>

        <!-- Discord URL -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Discord URL:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <TextBox Grid.Row="5" Grid.Column="1"
                 Text="{Binding DiscordUrl, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,8"/>

        <!-- Website URL -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Website URL:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <TextBox Grid.Row="6" Grid.Column="1"
                 Text="{Binding WebsiteUrl, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,8"/>

        <!-- Default Rodat -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Default Rodat:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding DefaultRodat}"
                  Content="Enabled" VerticalAlignment="Center" Margin="0,0,0,8"/>

        <!-- Secure Logon -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Secure Logon:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"/>
        <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding SecureLogon}"
                  Content="Enabled" VerticalAlignment="Center" Margin="0,0,0,8"/>

        <!-- Custom Dat Registry (Dat Developer Mode only) -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Custom Dat Path:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"
                   Visibility="{Binding IsDatDeveloperMode, Converter={StaticResource BoolToVisibility}}"
                   ToolTip="Local folder containing DAT files. If both are filled in, the local path takes priority."/>
        <Grid Grid.Row="9" Grid.Column="1" Margin="0,0,0,8"
              Visibility="{Binding IsDatDeveloperMode, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding CustomDatRegistryPath, UpdateSourceTrigger=PropertyChanged}"
                     Padding="4,3"
                     ToolTip="Local folder path containing DAT files for this server. When set, the community DAT registry is not consulted. Takes priority over the zip URL if both are filled."/>
            <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="10,4"
                    Click="BrowseCustomDatRegistry_Click"/>
        </Grid>

        <!-- OR divider (Dat Developer Mode only) -->
        <Grid Grid.Row="10" Grid.ColumnSpan="2" Margin="0,0,0,8"
              Visibility="{Binding IsDatDeveloperMode, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0" Height="1" Fill="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="— OR —" Foreground="#555" FontSize="10"
                       Margin="8,0" VerticalAlignment="Center"/>
            <Rectangle Grid.Column="2" Height="1" Fill="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Custom Dat Zip URL (Dat Developer Mode only) -->
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Custom Dat URL:" VerticalAlignment="Center"
                   FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,10,8"
                   Visibility="{Binding IsDatDeveloperMode, Converter={StaticResource BoolToVisibility}}"
                   ToolTip="Hosted zip URL containing DAT files. Used when no local path is set — lets remote devs pull the same DATs."/>
        <TextBox Grid.Row="11" Grid.Column="1" Margin="0,0,0,8"
                 Text="{Binding CustomDatZipUrl, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3"
                 Visibility="{Binding IsDatDeveloperMode, Converter={StaticResource BoolToVisibility}}"
                 ToolTip="A direct link to a zip archive of DAT files (e.g. private file host, S3). Downloaded once and cached locally. Local path takes priority if both are filled."/>

        <!-- Error -->
        <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Text="{Binding ErrorText}"
                   Foreground="#E53935" VerticalAlignment="Center"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="13" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="{Binding SaveButtonLabel}" Padding="16,6" FontWeight="Bold"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
