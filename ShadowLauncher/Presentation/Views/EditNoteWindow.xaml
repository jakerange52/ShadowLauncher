<Window x:Class="ShadowLauncher.Presentation.Views.EditNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Note" Height="180" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F2121216" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="#F2121216" CornerRadius="12" BorderBrush="#2A2A30" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock x:Name="TitleText" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,24,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Note" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" x:Name="NoteTextBox" Padding="4,3" Margin="0,0,0,12"
                 AcceptsReturn="False"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Padding="16,6" FontWeight="Bold" Click="Save_Click"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
