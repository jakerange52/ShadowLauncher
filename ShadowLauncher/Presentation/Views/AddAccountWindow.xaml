<Window x:Class="ShadowLauncher.Presentation.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Account" Height="220" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Add Account" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Username" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,4"/>
        <TextBox Grid.Row="1" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Padding="4,3" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="Password" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,4"/>
        <PasswordBox Grid.Row="3" x:Name="PasswordBox" Padding="4,3" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Text="{Binding ErrorText}" Foreground="#E53935"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Add" Padding="16,6" FontWeight="Bold"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
