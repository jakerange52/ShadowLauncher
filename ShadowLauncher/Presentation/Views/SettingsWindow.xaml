<Window x:Class="ShadowLauncher.Presentation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShadowLauncher.Presentation.Converters"
        Title="Settings" Height="280" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Settings" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Decal Path -->
        <TextBlock Grid.Row="0" Text="Custom Decal Inject" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,4"/>
        <CheckBox Grid.Row="0" IsChecked="{Binding AttemptDecalInjection}"
                  Content="Attempt Decal Injection" Foreground="#E8A838" FontSize="11" FontWeight="SemiBold"
                  HorizontalAlignment="Right" VerticalAlignment="Center"
                  ToolTip="Leave the path below blank for a standard Decal install. Uncheck to always launch acclient directly without attempting Decal injection."/>
        <Grid Grid.Row="1" VerticalAlignment="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding DecalPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Padding="4,3"/>
            <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="12,4"
                    Command="{Binding BrowseDecalCommand}"/>
        </Grid>

        <!-- Open User File -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="&#x1F4C2; Open Accounts File" HorizontalAlignment="Left"
                    Padding="12,4" Margin="0,0,8,0"
                    Command="{Binding OpenUserFileCommand}"
                    ToolTip="Opens the accounts.txt file in your default editor"/>
            <Button Content="Global Login Commands" HorizontalAlignment="Left"
                    Padding="12,4" Margin="0,0,8,0"
                    Click="OpenLoginCommands_Click"
                    ToolTip="Edit global login commands sent after character login (requires ShadowFilter or ThwargFilter)"/>
            <Button Content="&#x1F464; Per Character" HorizontalAlignment="Left"
                    Padding="12,4" Margin="0,0,8,0"
                    Click="OpenPerCharacterLoginCommands_Click"
                    ToolTip="Edit login commands for specific characters only"/>
            <Button Content="Edit Profiles" HorizontalAlignment="Left"
                    Padding="12,4"
                    Click="OpenEditProfiles_Click"
                    ToolTip="Rename or delete launch profiles"/>
        </StackPanel>

        <!-- Open DAT Cache -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Open DAT Cache" Padding="12,4" Margin="0,0,12,0"
                    Click="OpenDatCache_Click"
                    ToolTip="Open the folder where downloaded DAT files are cached"/>
        </StackPanel>

        <!-- Footer: keep on Auto row so buttons don't stretch into the * spacer above -->
        <DockPanel Grid.Row="5" VerticalAlignment="Bottom">
            <StackPanel DockPanel.Dock="Left" Orientation="Vertical" Margin="0,0,8,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" Foreground="Gray"
                           VerticalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Check for Updates" Padding="12,6"
                            Command="{Binding CheckForUpdatesCommand}"
                            Visibility="{Binding IsDownloading, Converter={StaticResource InverseBoolToVisibility}}"
                            ToolTip="Check GitHub for a newer version of ShadowLauncher"/>
                    <CheckBox IsChecked="{Binding DatDeveloperMode}" VerticalAlignment="Center"
                              Margin="12,0,0,0"
                              Content="Dat Developer Mode" Foreground="#E8A838" FontWeight="SemiBold"
                              ToolTip="Enables a Custom Dat Registry field when adding servers, bypassing the community DAT registry for that server."/>
                </StackPanel>
                <!-- Download progress (visible only while downloading) -->
                <ProgressBar Minimum="0" Maximum="100"
                             Value="{Binding DownloadProgress}"
                             Height="16" Margin="0,4,0,0"
                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"
                             ToolTip="{Binding StatusText}"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="&#x2753; Help" Padding="12,6" Margin="0,0,8,0"
                        Click="OpenHelp_Click" ToolTip="Setup instructions (ThwargFilter welcome; ShadowFilter optional)"/>
                <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Save" Padding="16,6" FontWeight="Bold"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
