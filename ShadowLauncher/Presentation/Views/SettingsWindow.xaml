<Window x:Class="ShadowLauncher.Presentation.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShadowLauncher.Presentation.Converters"
        Title="Settings" Height="280" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F2121216" WindowStyle="None" AllowsTransparency="True">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="#F2121216" CornerRadius="12" BorderBrush="#2A2A30" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Settings" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,20,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Decal Path -->
        <TextBlock Grid.Row="0" Text="Decal Inject Path (optional)" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,4"/>
        <Grid Grid.Row="1" VerticalAlignment="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding DecalPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Padding="4,3"/>
            <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0" Padding="12,4"
                    Command="{Binding BrowseDecalCommand}"/>
        </Grid>

        <!-- Open User File -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="&#x1F4C2; Open Accounts File" HorizontalAlignment="Left"
                    Padding="12,4" Margin="0,0,8,0"
                    Command="{Binding OpenUserFileCommand}"
                    ToolTip="Opens the accounts.txt file in your default editor"/>
            <Button Content="Global Login Commands" HorizontalAlignment="Left"
                    Padding="12,4" Margin="0,0,8,0"
                    Click="OpenLoginCommands_Click"
                    ToolTip="Edit global login commands sent after login via ThwargFilter (all characters)"/>
            <Button Content="&#x1F464; Per Character" HorizontalAlignment="Left"
                    Padding="12,4"
                    Click="OpenPerCharacterLoginCommands_Click"
                    ToolTip="Edit login commands for specific characters only"/>
        </StackPanel>

        <!-- Footer -->
        <DockPanel Grid.Row="4">
            <Button DockPanel.Dock="Left" Content="&#x2753; Help" Padding="12,6"
                    Click="OpenHelp_Click" ToolTip="Setup instructions for multi-clienting"/>
            <Button DockPanel.Dock="Left" Content="Check for Updates" Padding="12,6" Margin="8,0,0,0"
                    Command="{Binding CheckForUpdatesCommand}"
                    Visibility="{Binding IsDownloading, Converter={StaticResource InverseBoolToVisibility}}"
                    ToolTip="Check GitHub for a newer version of ShadowLauncher"/>
            <!-- Download progress (visible only while downloading) -->
            <ProgressBar DockPanel.Dock="Left" Minimum="0" Maximum="100"
                         Value="{Binding DownloadProgress}"
                         Width="120" Height="16" Margin="8,0,0,0"
                         Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"
                         ToolTip="{Binding StatusText}"/>
            <TextBlock DockPanel.Dock="Left" Text="{Binding StatusText}" Foreground="Gray"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
            <TextBlock DockPanel.Dock="Left" Text="{Binding CurrentVersion}" Foreground="#444"
                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Save" Padding="16,6" FontWeight="Bold"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
