<Window x:Class="ShadowLauncher.Presentation.Views.ServerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ShadowLauncher.Presentation.Converters"
        Title="Server Details" SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F2121216" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <converters:OnlineStatusColorConverter x:Key="OnlineStatusColorConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="#2A2A30" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF0C0C10" Offset="0"/>
                <GradientStop Color="#F214141C" Offset="0.5"/>
                <GradientStop Color="#E60F0F14" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid Margin="16">
            <!-- Title bar -->
            <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28"
                       WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="Server Details" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                        Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"/>
            </DockPanel>

            <!-- Business card body -->
            <StackPanel Margin="0,28,0,0" x:Name="CardPanel">

                <!-- Header: status dot + server name + emulator badge -->
                <DockPanel Margin="0,0,0,8">
                    <Border DockPanel.Dock="Right" CornerRadius="4" Padding="6,2"
                            Background="#2A2A30" VerticalAlignment="Center">
                        <TextBlock x:Name="EmuLabel" FontSize="11" FontWeight="Bold" Foreground="#AAA"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ServerNameLabel" FontSize="20" FontWeight="Bold"
                                   Foreground="#F0F0F0" FontFamily="{DynamicResource TitleFont}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>

                <!-- Divider -->
                <Rectangle Height="1" Fill="#3A3A40" Margin="0,0,0,10"/>

                <!-- Description -->
                <TextBlock x:Name="DescriptionLabel" TextWrapping="Wrap" Foreground="#CCC"
                           FontStyle="Italic" Margin="0,0,0,12" LineHeight="20"
                           Visibility="Collapsed"/>

                <!-- Details grid -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Host:Port -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Host" Foreground="#666"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,12,5" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HostLabel"
                               Foreground="#DDD" FontSize="12" Margin="0,0,0,5" VerticalAlignment="Center"/>

                    <!-- Published status -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Status" Foreground="#666"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,12,5" VerticalAlignment="Center"
                               x:Name="StatusRowLabel"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PublishedStatusLabel"
                               Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"
                               VerticalAlignment="Center"/>

                    <!-- Rodat -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Rodat" Foreground="#666"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,12,5" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RodatLabel"
                               Foreground="#AAA" FontSize="12" Margin="0,0,0,5" VerticalAlignment="Center"/>

                    <!-- Secure Logon -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Secure Logon" Foreground="#666"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,12,5" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SecureLogonLabel"
                               Foreground="#AAA" FontSize="12" Margin="0,0,0,5" VerticalAlignment="Center"/>
                </Grid>

                <!-- Divider before links -->
                <Rectangle Height="1" Fill="#3A3A40" Margin="0,0,0,10"
                           x:Name="LinksDivider" Visibility="Collapsed"/>

                <!-- Discord / Website buttons -->
                <StackPanel Orientation="Horizontal" x:Name="LinksPanel" Visibility="Collapsed">
                    <Button x:Name="DiscordButton" Content="Discord" Padding="16,6" Margin="0,0,8,0"
                            Click="Discord_Click" Visibility="Collapsed"/>
                    <Button x:Name="WebsiteButton" Content="Website" Padding="16,6"
                            Click="Website_Click" Visibility="Collapsed"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
