<Window x:Class="ShadowLauncher.Presentation.Views.PerCharacterLoginCommandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login Commands Per Character" Height="450" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F2121216" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Border Background="#F2121216" CornerRadius="12" BorderBrush="#2A2A30" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Login Commands Per Character" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,24,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="#AAA" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                   Text="Set login commands for specific characters. Click Edit to set commands for that character."/>

        <DataGrid Grid.Row="1" x:Name="CharacterGrid" AutoGenerateColumns="False"
                  IsReadOnly="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" Width="140" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Character" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding AvailableCharacters}"
                                      SelectedItem="{Binding CharacterName, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      Background="#2A2A30" Foreground="#EEE">
                                <ComboBox.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A30"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEE"/>
                                </ComboBox.Resources>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Commands Preview" Binding="{Binding CommandsPreview}" Width="*" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Edit" Padding="8,2" Click="EditCommands_Click"
                                    Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Foreground="#4CAF50" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="&#x1F504; Refresh" Padding="12,6" Margin="0,0,8,0" Click="Refresh_Click"/>
                <Button Content="Save" Padding="16,6" Margin="0,0,8,0" FontWeight="Bold" Click="Save_Click"/>
                <Button Content="Close" Padding="16,6" Click="Close_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
