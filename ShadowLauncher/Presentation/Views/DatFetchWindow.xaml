<Window x:Class="ShadowLauncher.Presentation.Views.DatFetchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShadowLauncher.Presentation.Views"
        Title="ShadowLauncher" Height="196" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#F2121216" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <Border Background="#F2121216" CornerRadius="12" BorderBrush="#3A3A40" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="6" Opacity="0.7"/>
        </Border.Effect>
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="⚔" FontFamily="Segoe UI Symbol" FontSize="16"
                           Foreground="#661111" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Fetching DATs" FontFamily="Gabriola, Palatino Linotype, Georgia, serif"
                           FontSize="18" FontWeight="SemiBold" Foreground="#DDDDDD"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Grid.Row="1" Height="1" Fill="#3A3A40" Margin="0,0,0,12"/>

            <!-- Status text -->
            <TextBlock Grid.Row="2" Margin="0,0,0,4"
                       Text="{Binding StatusText}"
                       FontFamily="Palatino Linotype, Book Antiqua, Georgia, serif"
                       FontSize="12" Foreground="#DDDDDD"/>

            <!-- Filename -->
            <TextBlock Grid.Row="3" Margin="0,0,0,10"
                       Text="{Binding FileName}"
                       FontFamily="Palatino Linotype, Book Antiqua, Georgia, serif"
                       FontSize="11" Foreground="#888888"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Overall progress bar -->
            <ProgressBar Grid.Row="4" Height="10" Margin="0,0,0,6"
                         Value="{Binding OverallProgress}" Maximum="100"
                         Background="#252528" BorderBrush="#3A3A40" BorderThickness="1">
                <ProgressBar.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#661111" Offset="0"/>
                        <GradientStop Color="#8C2222" Offset="1"/>
                    </LinearGradientBrush>
                </ProgressBar.Foreground>
                <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <Grid ClipToBounds="True">
                                <Rectangle x:Name="PART_Track"/>
                                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" CornerRadius="5"/>
                                </Decorator>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </ProgressBar.Template>
            </ProgressBar>

            <!-- Per-file byte progress (hidden during zip extraction) -->
            <ProgressBar Grid.Row="5" Height="5"
                         Value="{Binding FileProgress}" Maximum="100"
                         Background="#1A1A1E" BorderBrush="#3A3A40" BorderThickness="1"
                         Visibility="{Binding IsExtracting, Converter={StaticResource InvBoolToVis}}">
                <ProgressBar.Foreground>
                    <SolidColorBrush Color="#3A3A40"/>
                </ProgressBar.Foreground>
                <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid ClipToBounds="True">
                                <Rectangle x:Name="PART_Track"/>
                                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" CornerRadius="3"/>
                                </Decorator>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </ProgressBar.Template>
            </ProgressBar>

            <!-- Indeterminate bar while extracting zip -->
            <ProgressBar Grid.Row="6" Height="5" IsIndeterminate="True" Margin="0,1,0,0"
                         Background="#1A1A1E" BorderBrush="#3A3A40" BorderThickness="1"
                         Foreground="#3A3A40"
                         Visibility="{Binding IsExtracting, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Border>
</Window>
