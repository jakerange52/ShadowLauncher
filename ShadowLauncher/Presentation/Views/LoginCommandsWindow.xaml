<Window x:Class="ShadowLauncher.Presentation.Views.LoginCommandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login Commands" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F2121216" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Border Background="#F2121216" CornerRadius="12" BorderBrush="#2A2A30" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Login Commands (ThwargFilter)" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,24,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="#AAA" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"
                   Text="Commands are sent as chat messages after login (one per line). Uses ThwargFilter. Example: /allegiance recall"/>

        <TextBlock Grid.Row="1" Text="Global Commands (all characters)" FontWeight="SemiBold" Foreground="#AAA" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="CommandsTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Padding="6,4" MinHeight="120"/>

        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left" Text="Wait after login (ms):" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="WaitMsTextBox" Width="60" Padding="4,3" VerticalContentAlignment="Center"/>
        </DockPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save" Padding="16,6" FontWeight="Bold" Click="Save_Click"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
