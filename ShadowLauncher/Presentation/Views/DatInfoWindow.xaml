<Window x:Class="ShadowLauncher.Presentation.Views.DatInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DAT Info" Height="420" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        MinWidth="480" MinHeight="280"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid Margin="16">
            <!-- Title bar -->
            <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
                <TextBlock x:Name="TitleText" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11"
                        Click="Close_Click" Style="{DynamicResource IconButton}"
                        Foreground="#888" HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True"/>
            </DockPanel>

            <!-- Body -->
            <Grid Margin="0,28,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="SubtitleText"
                           Foreground="#888" FontSize="11" Margin="0,0,0,8"/>

                <!-- Scrollable, selectable text area -->
                <TextBox Grid.Row="1"
                         x:Name="InfoBox"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="11"
                         Padding="8"
                         Background="{DynamicResource InputBgBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"/>

                <!-- Footer -->
                <DockPanel Grid.Row="2" Margin="0,10,0,0">
                    <TextBlock x:Name="StatusText" Foreground="#666" FontSize="11"
                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Copy All" Padding="14,6" Margin="0,0,8,0" Click="CopyAll_Click"/>
                        <Button Content="Close" Padding="14,6" Click="Close_Click"/>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
