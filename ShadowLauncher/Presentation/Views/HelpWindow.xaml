<Window x:Class="ShadowLauncher.Presentation.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Setup Help" Height="620" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Setup Help" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,24,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="4">
            <!-- Step 1: UserPreferences -->
            <TextBlock Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                <Run FontWeight="Bold" Foreground="#E85050">Step 1: Configure UserPreferences</Run>
                <LineBreak/><LineBreak/>
                <Run>Using this method of multi-clienting only requires a single install of AC.</Run>
                <LineBreak/><LineBreak/>
                <Run>Locate your Documents\Asheron's Call\UserPreferences.ini and open with a text editor.</Run>
                <LineBreak/><LineBreak/>
                <Run>A button is included below that will attempt to open the file at its default location.</Run>
                <LineBreak/><LineBreak/>
                <Run FontWeight="Bold">Find [Net] and change ComputeUniquePort to True and save.</Run>
            </TextBlock>

            <Button Content="Open Preferences Default Location" Padding="10,5" Margin="0,0,0,6"
                    HorizontalAlignment="Stretch" Click="OpenPreferences_Click"/>

            <Image Source="/Presentation/Images/Help/UserPreferences.png"
                   MaxHeight="140" MaxWidth="280" HorizontalAlignment="Left" Margin="0,0,0,8"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <Border Height="2" Background="#E85050" Margin="0,2,0,8" HorizontalAlignment="Stretch"/>

            <!-- Step 2: Decal -->
            <TextBlock Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                <Run FontWeight="Bold" Foreground="#E85050">Step 2: Configure Decal</Run>
                <LineBreak/><LineBreak/>
                <Run>Update Decal so the red X’s turn to black check marks.</Run>
                <LineBreak/><LineBreak/>
                <Run FontWeight="SemiBold" Foreground="#E8A838">Already have ThwargFilter?</Run>
                <Run> Keep it enabled — ShadowLauncher writes ThwargFilter launch files for character auto-login. You do not need ShadowFilter.</Run>
                <LineBreak/><LineBreak/>
                <Run FontWeight="SemiBold" Foreground="#E8A838">Optional — ShadowFilter:</Run>
                <Run> If you want ShadowLauncher’s first-party filter instead (or in addition), click Add then Browse, open the ShadowLauncher\ShadowFilter folder, select ShadowFilter.dll, and Save.</Run>
                <LineBreak/>
                <Run FontWeight="SemiBold" Foreground="#888">(default: C:\Program Files (x86)\ShadowLauncher\ShadowFilter)</Run>
            </TextBlock>

            <Image Source="/Presentation/Images/Help/DecalSetting.png"
                   MaxHeight="240" MaxWidth="280" HorizontalAlignment="Left" Margin="0,0,0,8"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <Border Height="2" Background="#E85050" Margin="0,2,0,8" HorizontalAlignment="Stretch"/>

            <!-- Credits -->
            <Image Source="/Presentation/Images/Help/Credit.PNG"
                   MaxHeight="50" MaxWidth="270" HorizontalAlignment="Left" Margin="0,0,0,4"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock Foreground="#888" FontSize="10" Margin="0,0,0,0" TextWrapping="Wrap">
                <Run>Thanks to the Asheron's Call / Decal community whose tools and patterns made this possible.</Run>
                <LineBreak/>
                <Run>Questions or feedback? Discord: @elrek</Run>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Ok" Padding="24,6" FontWeight="Bold" Click="Close_Click"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
