<Window x:Class="ShadowLauncher.Presentation.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" Height="220" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="12" GlassFrameThickness="0" CaptionHeight="28" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid Margin="16">
        <DockPanel VerticalAlignment="Top" Margin="0,-8,0,0" Height="28">
            <TextBlock Text="Update Available" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <Button DockPanel.Dock="Right" Content="&#x2715;" Padding="8,2" FontSize="11" Click="Close_Click"
                    Style="{DynamicResource IconButton}" Foreground="#888" HorizontalAlignment="Right"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </DockPanel>
    <Grid Margin="0,24,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="SummaryText" TextWrapping="Wrap" Foreground="#DDD" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" x:Name="NotesText" Margin="0,0,0,8" Foreground="#AAA">
            <Hyperlink x:Name="NotesLink" Click="NotesLink_Click">full notes here</Hyperlink>
        </TextBlock>

        <TextBlock Grid.Row="2" Text="Download and install now? The app will restart automatically."
                   TextWrapping="Wrap" Foreground="#888" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Not now" Padding="16,6" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Install" Padding="16,6" FontWeight="Bold" IsDefault="True" Click="Install_Click"/>
        </StackPanel>
    </Grid>
    </Grid>
    </Border>
</Window>
