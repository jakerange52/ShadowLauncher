<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ═══════ Color Palette ═══════ -->
    <Color x:Key="ShadowBg">#0A0A0D</Color>
    <Color x:Key="ShadowSurface">#222226</Color>
    <Color x:Key="ShadowSurfaceAlt">#252528</Color>
    <Color x:Key="ShadowBorder">#3A3A40</Color>
    <Color x:Key="ShadowRed">#661111</Color>
    <Color x:Key="ShadowRedHover">#8C2222</Color>
    <Color x:Key="ShadowRedPress">#3A0000</Color>
    <Color x:Key="ShadowText">#DDDDDD</Color>
    <Color x:Key="ShadowTextMuted">#666666</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource ShadowBg}" Opacity="0.85"/>
    <!-- Surface: deep crimson with a soft inner glow bloom -->
    <DrawingBrush x:Key="SurfaceBrush"
                  TileMode="None"
                  Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox"
                  Viewbox="0,0,600,400" ViewboxUnits="Absolute"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Geometry="M0,0 H600 V400 H0 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                            <GradientStop Color="#301010" Offset="0.0"/>
                            <GradientStop Color="#220C0C" Offset="0.45"/>
                            <GradientStop Color="#180808" Offset="0.75"/>
                            <GradientStop Color="#100404" Offset="1.0"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H600 V400 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1" Opacity="0.25">
                            <GradientStop Color="#3A1010" Offset="0.0"/>
                            <GradientStop Color="#160808" Offset="0.5"/>
                            <GradientStop Color="#2A0C0C" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H600 V400 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                            <GradientStop Color="#100404" Offset="0.0"/>
                            <GradientStop Color="#3A1414" Offset="0.5"/>
                            <GradientStop Color="#180808" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource ShadowSurfaceAlt}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ShadowBorder}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource ShadowRed}"/>
    <SolidColorBrush x:Key="RedHoverBrush" Color="{StaticResource ShadowRedHover}"/>
    <SolidColorBrush x:Key="RedPressBrush" Color="{StaticResource ShadowRedPress}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ShadowText}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ShadowTextMuted}"/>
    <SolidColorBrush x:Key="BetaBadgeBrush" Color="#F5C842"/>

    <!-- ═══════ Theme contract (consumed by BaseTheme.xaml) ═══════ -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#D9080810"/>

    <SolidColorBrush x:Key="ButtonBgBrush" Color="{StaticResource ShadowRed}"/>
    <SolidColorBrush x:Key="ButtonFgBrush" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ShadowRedHover}"/>
    <SolidColorBrush x:Key="ButtonPressBrush" Color="{StaticResource ShadowRedPress}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
    <Thickness x:Key="ButtonBorderThickness">0</Thickness>
    <SolidColorBrush x:Key="ButtonDisabledBgBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ButtonDisabledFgBrush" Color="#666666"/>
    <Color x:Key="ButtonGlowColor">Black</Color>
    <sys:Double x:Key="ButtonGlowBlur">10</sys:Double>
    <sys:Double x:Key="ButtonGlowDepth">2</sys:Double>
    <sys:Double x:Key="ButtonGlowOpacity">0.6</sys:Double>

    <SolidColorBrush x:Key="IconFgBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="IconHoverBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ArrowFillBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="CaretBrush" Color="{StaticResource ShadowText}"/>

    <!-- DataGrid header + hovered list item: the crimson surface bloom -->
    <DrawingBrush x:Key="AltSurfaceBrush"
                  TileMode="None"
                  Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox"
                  Viewbox="0,0,600,400" ViewboxUnits="Absolute"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Geometry="M0,0 H600 V400 H0 Z">
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
                            <GradientStop Color="#301010" Offset="0.0"/>
                            <GradientStop Color="#220C0C" Offset="0.45"/>
                            <GradientStop Color="#180808" Offset="0.75"/>
                            <GradientStop Color="#100404" Offset="1.0"/>
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H600 V400 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1" Opacity="0.25">
                            <GradientStop Color="#3A1010" Offset="0.0"/>
                            <GradientStop Color="#160808" Offset="0.5"/>
                            <GradientStop Color="#2A0C0C" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H600 V400 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.15">
                            <GradientStop Color="#100404" Offset="0.0"/>
                            <GradientStop Color="#3A1414" Offset="0.5"/>
                            <GradientStop Color="#180808" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <SolidColorBrush x:Key="RowSelectedBgBrush" Color="#55661111"/>
    <SolidColorBrush x:Key="RowSelectedFgBrush" Color="{StaticResource ShadowText}"/>

    <SolidColorBrush x:Key="ListSelectedFgBrush" Color="White"/>
    <SolidColorBrush x:Key="SelectedFgBrush" Color="White"/>

    <SolidColorBrush x:Key="TrackBrush" Color="#1A1A20"/>
    <SolidColorBrush x:Key="ThumbBrush" Color="#3A3A40"/>
    <SolidColorBrush x:Key="ThumbHoverBrush" Color="#555555"/>

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="BaseTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
