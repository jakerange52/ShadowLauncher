<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════ Color Palette — AC Classic: blue outer, reddish-brown inner, gold trim ═══════ -->
    <FontFamily x:Key="FantasyFont">Palatino Linotype, Book Antiqua, Georgia, serif</FontFamily>
    <FontFamily x:Key="TitleFont">Gabriola, Palatino Linotype, Georgia, serif</FontFamily>
    <FontFamily x:Key="EmojiFont">Segoe UI, Segoe UI Emoji, Segoe UI Symbol</FontFamily>

    <Color x:Key="ShadowBg">#0E1B30</Color>
    <Color x:Key="ShadowSurface">#3A1A0A</Color>
    <Color x:Key="ShadowSurfaceAlt">#4A2210</Color>
    <Color x:Key="ShadowBorder">#C8900A</Color>
    <Color x:Key="ShadowRed">#4A2210</Color>
    <Color x:Key="ShadowRedHover">#5E2C14</Color>
    <Color x:Key="ShadowRedPress">#2A1006</Color>
    <Color x:Key="ShadowText">#F0D878</Color>
    <Color x:Key="ShadowTextMuted">#8A6A20</Color>

    <!-- Blue outer — gradient base with soft cross-faded overlay layers for fuzziness -->
    <DrawingBrush x:Key="BgBrush"
                  TileMode="None"
                  Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox"
                  Viewbox="0,0,900,660" ViewboxUnits="Absolute"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Base gradient: top-left dark to bottom-right mid-blue -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#080F1C" Offset="0.00"/>
                            <GradientStop Color="#0E1B30" Offset="0.18"/>
                            <GradientStop Color="#0A1422" Offset="0.31"/>
                            <GradientStop Color="#162540" Offset="0.47"/>
                            <GradientStop Color="#0C1828" Offset="0.60"/>
                            <GradientStop Color="#1A2B4A" Offset="0.75"/>
                            <GradientStop Color="#0F1E34" Offset="0.88"/>
                            <GradientStop Color="#142238" Offset="1.00"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Soft perpendicular cross-fade — blurs the gradient edges -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1" Opacity="0.35">
                            <GradientStop Color="#0A1422" Offset="0.0"/>
                            <GradientStop Color="#142238" Offset="0.4"/>
                            <GradientStop Color="#080F1C" Offset="0.7"/>
                            <GradientStop Color="#0E1B30" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Vertical soft wash — softens horizontal banding -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.25">
                            <GradientStop Color="#162540" Offset="0.0"/>
                            <GradientStop Color="#080F1C" Offset="0.5"/>
                            <GradientStop Color="#1A2B4A" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Diagonal opposite — breaks up any remaining linearity -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.2,1" EndPoint="0.8,0" Opacity="0.20">
                            <GradientStop Color="#0C1828" Offset="0.0"/>
                            <GradientStop Color="#162540" Offset="0.45"/>
                            <GradientStop Color="#0A1422" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Brown inner surface — organic stain blobs, no tiling, near-invisible variation -->
    <DrawingBrush x:Key="SurfaceBrush"
                  TileMode="None"
                  Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox"
                  Viewbox="0,0,900,600" ViewboxUnits="Absolute"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Base -->
                <GeometryDrawing Brush="#3A1A0A" Geometry="M0,0 H900 V600 H0 Z"/>
                <!-- Blobs — all within ±2 of base, spread across the full surface -->
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="80,90"   RadiusX="120" RadiusY="80"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="300,60"  RadiusX="160" RadiusY="70"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="600,80"  RadiusX="140" RadiusY="90"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#391909"><GeometryDrawing.Geometry><EllipseGeometry Center="820,50"  RadiusX="100" RadiusY="110"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="150,260" RadiusX="130" RadiusY="150"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="450,200" RadiusX="200" RadiusY="120"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3B1B0B"><GeometryDrawing.Geometry><EllipseGeometry Center="750,300" RadiusX="160" RadiusY="140"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A190A"><GeometryDrawing.Geometry><EllipseGeometry Center="50,420"  RadiusX="110" RadiusY="130"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="280,450" RadiusX="170" RadiusY="100"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#391909"><GeometryDrawing.Geometry><EllipseGeometry Center="560,480" RadiusX="150" RadiusY="120"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="840,430" RadiusX="90"  RadiusY="160"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="400,560" RadiusX="220" RadiusY="80"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="700,560" RadiusX="130" RadiusY="90"/></GeometryDrawing.Geometry></GeometryDrawing>
                <!-- A few smaller accent drips -->
                <GeometryDrawing Brush="#381809"><GeometryDrawing.Geometry><EllipseGeometry Center="200,150" RadiusX="55"  RadiusY="40"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="680,200" RadiusX="60"  RadiusY="45"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#391909"><GeometryDrawing.Geometry><EllipseGeometry Center="500,350" RadiusX="50"  RadiusY="70"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="120,510" RadiusX="65"  RadiusY="45"/></GeometryDrawing.Geometry></GeometryDrawing>
                <!-- Soft blur layers over the blobs — cross-angled low-opacity gradients -->
                <GeometryDrawing Geometry="M0,0 H900 V600 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1" Opacity="0.30">
                            <GradientStop Color="#3A1A0A" Offset="0.0"/>
                            <GradientStop Color="#391808" Offset="0.4"/>
                            <GradientStop Color="#3B1B0B" Offset="0.7"/>
                            <GradientStop Color="#3A1909" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H900 V600 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.20">
                            <GradientStop Color="#3B1B0B" Offset="0.0"/>
                            <GradientStop Color="#391808" Offset="0.5"/>
                            <GradientStop Color="#3A1A0A" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H900 V600 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.2,1" EndPoint="0.8,0" Opacity="0.15">
                            <GradientStop Color="#391909" Offset="0.0"/>
                            <GradientStop Color="#3A1A0A" Offset="0.5"/>
                            <GradientStop Color="#381808" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Title text uses RedBrush — override to gold in Classic -->
    <SolidColorBrush x:Key="RedBrush"          Color="#C8900A"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"   Color="{StaticResource ShadowSurfaceAlt}"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="{StaticResource ShadowBorder}"/>
    <SolidColorBrush x:Key="RedHoverBrush"     Color="{StaticResource ShadowRedHover}"/>
    <SolidColorBrush x:Key="RedPressBrush"     Color="{StaticResource ShadowRedPress}"/>
    <SolidColorBrush x:Key="TextBrush"         Color="{StaticResource ShadowText}"/>
    <SolidColorBrush x:Key="TextMutedBrush"    Color="{StaticResource ShadowTextMuted}"/>
    <SolidColorBrush x:Key="BetaBadgeBrush" Color="#F5C842"/>
    <SolidColorBrush x:Key="GoldBrush"         Color="#C8900A"/>
    <!-- Used for highlighted/selected foreground in menus and dropdowns instead of gold,
         which becomes unreadable against light selection backgrounds. -->
    <SolidColorBrush x:Key="HighlightFgBrush"  Color="#1A3A5C"/>

    <!-- ═══════ Window ═══════ -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="#0E1B30"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CornerRadius="12" GlassFrameThickness="-1"
                              CaptionHeight="32" ResizeBorderThickness="6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Launch Button — purple vortex style ═══════ -->
    <Style x:Key="LaunchButton" TargetType="Button">
        <Setter Property="Background" Value="#5B2D8E"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5"
                            TextElement.FontFamily="{StaticResource EmojiFont}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <Border.Effect>
                            <DropShadowEffect Color="#7B3DBE" BlurRadius="10" ShadowDepth="1" Opacity="0.5"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#7040AA"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#3A1A6A"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#2E1A50"/>
                            <Setter Property="Foreground" Value="#7A6030"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style TargetType="Button">
        <Setter Property="Background" Value="#4A2210"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5"
                            TextElement.FontFamily="{StaticResource EmojiFont}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <Border.Effect>
                            <DropShadowEffect Color="#D4A017" BlurRadius="8" ShadowDepth="1" Opacity="0.4"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#5E2C14"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2A1006"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#4A3A20"/>
                            <Setter Property="Foreground" Value="#7A6030"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Grid Action Button (compact, used in DataGrid cells/headers) ═══════ -->
    <Style x:Key="GridActionButton" TargetType="Button">
        <Setter Property="Background" Value="#0E1B30"/>
        <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource RedHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource RedPressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Icon Button ═══════ -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource EmojiFont}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5"
                            TextElement.FontFamily="{StaticResource EmojiFont}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#3A2A10"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ GroupBox ═══════ -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="8,4" Background="{StaticResource SurfaceAltBrush}"
                                CornerRadius="6,6,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,1,1,0">
                            <TextBlock Text="{TemplateBinding Header}" FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}" FontSize="13"/>
                        </Border>
                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                                CornerRadius="0,0,6,6" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,0,1,1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ ListBox ═══════ -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Padding" Value="4,3"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource RedBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════ TextBox ═══════ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource RedBrush}"/>
    </Style>

    <!-- ═══════ PasswordBox ═══════ -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource RedBrush}"/>
    </Style>

    <!-- ═══════ CheckBox ═══════ -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="checkBorder"
                                Width="16" Height="16"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                            <Path x:Name="checkMark"
                                  Data="M 2 8 L 6 12 L 13 4"
                                  Stroke="{StaticResource GoldBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="checkBorder" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="checkBorder" Property="BorderBrush" Value="{StaticResource RedHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ ComboBox ═══════ -->
    <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Border" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"/>
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderThickness="0" CornerRadius="3,0,0,3" Margin="1"/>
            <Path x:Name="Arrow" Grid.Column="1" Fill="#D4A017" HorizontalAlignment="Center" VerticalAlignment="Center"
                  Data="M 0 0 L 4 4 L 8 0 Z"/>
        </Grid>
    </ControlTemplate>
    <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
        <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}"/>
    </ControlTemplate>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="MinHeight" Value="25"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}"
                                      Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="6,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                        <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}"
                                 Template="{StaticResource ComboBoxTextBox}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                 Margin="6,3,23,3" Focusable="True" Background="Transparent"
                                 Foreground="{StaticResource TextBrush}" CaretBrush="{StaticResource GoldBrush}"
                                 Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                        <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid Name="DropDown" SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder" Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"/>
                                <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter Property="IsTabStop" Value="False"/>
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="4,2" BorderThickness="0">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource RedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource HighlightFgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource RedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource HighlightFgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ TextBlock ═══════ -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
    </Style>

    <!-- ═══════ DataGrid ═══════ -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#55C8900A"/>
                <Setter Property="Foreground" Value="{StaticResource HighlightFgBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="MinWidth" Value="12"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="12"/>
                <Setter Property="MinHeight" Value="12"/>
                <Setter Property="Width" Value="Auto"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource RedHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="{StaticResource RedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════ ToolTip ═══════ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyFont}"/>
    </Style>

    <!-- ═══════ ContextMenu ═══════ -->
    <Style TargetType="ContextMenu">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <StackPanel IsItemsHost="True" ClipToBounds="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ MenuItem ═══════ -->
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="menuItemBorder" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Header}" Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="menuItemBorder" Property="Background" Value="{StaticResource RedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource HighlightFgBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
