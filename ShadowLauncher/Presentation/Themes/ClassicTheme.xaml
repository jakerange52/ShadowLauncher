<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ═══════ Color Palette — AC Classic: blue outer, reddish-brown inner, gold trim ═══════ -->
    <Color x:Key="ShadowBg">#0E1B30</Color>
    <Color x:Key="ShadowSurface">#3A1A0A</Color>
    <Color x:Key="ShadowSurfaceAlt">#4A2210</Color>
    <Color x:Key="ShadowBorder">#C8900A</Color>
    <Color x:Key="ShadowRed">#4A2210</Color>
    <Color x:Key="ShadowRedHover">#5E2C14</Color>
    <Color x:Key="ShadowRedPress">#2A1006</Color>
    <Color x:Key="ShadowText">#F0D878</Color>
    <Color x:Key="ShadowTextMuted">#8A6A20</Color>

    <!-- Blue outer — gradient base with soft cross-faded overlay layers for fuzziness -->
    <DrawingBrush x:Key="BgBrush"
                  TileMode="None"
                  Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox"
                  Viewbox="0,0,900,660" ViewboxUnits="Absolute"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Base gradient: top-left dark to bottom-right mid-blue -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#080F1C" Offset="0.00"/>
                            <GradientStop Color="#0E1B30" Offset="0.18"/>
                            <GradientStop Color="#0A1422" Offset="0.31"/>
                            <GradientStop Color="#162540" Offset="0.47"/>
                            <GradientStop Color="#0C1828" Offset="0.60"/>
                            <GradientStop Color="#1A2B4A" Offset="0.75"/>
                            <GradientStop Color="#0F1E34" Offset="0.88"/>
                            <GradientStop Color="#142238" Offset="1.00"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Soft perpendicular cross-fade — blurs the gradient edges -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1" Opacity="0.35">
                            <GradientStop Color="#0A1422" Offset="0.0"/>
                            <GradientStop Color="#142238" Offset="0.4"/>
                            <GradientStop Color="#080F1C" Offset="0.7"/>
                            <GradientStop Color="#0E1B30" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Vertical soft wash — softens horizontal banding -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.25">
                            <GradientStop Color="#162540" Offset="0.0"/>
                            <GradientStop Color="#080F1C" Offset="0.5"/>
                            <GradientStop Color="#1A2B4A" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <!-- Diagonal opposite — breaks up any remaining linearity -->
                <GeometryDrawing Geometry="M0,0 H900 V660 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.2,1" EndPoint="0.8,0" Opacity="0.20">
                            <GradientStop Color="#0C1828" Offset="0.0"/>
                            <GradientStop Color="#162540" Offset="0.45"/>
                            <GradientStop Color="#0A1422" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Brown inner surface — organic stain blobs, no tiling, near-invisible variation -->
    <DrawingBrush x:Key="SurfaceBrush"
                  TileMode="None"
                  Viewport="0,0,1,1" ViewportUnits="RelativeToBoundingBox"
                  Viewbox="0,0,900,600" ViewboxUnits="Absolute"
                  Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Base -->
                <GeometryDrawing Brush="#3A1A0A" Geometry="M0,0 H900 V600 H0 Z"/>
                <!-- Blobs — all within ±2 of base, spread across the full surface -->
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="80,90"   RadiusX="120" RadiusY="80"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="300,60"  RadiusX="160" RadiusY="70"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="600,80"  RadiusX="140" RadiusY="90"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#391909"><GeometryDrawing.Geometry><EllipseGeometry Center="820,50"  RadiusX="100" RadiusY="110"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="150,260" RadiusX="130" RadiusY="150"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="450,200" RadiusX="200" RadiusY="120"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3B1B0B"><GeometryDrawing.Geometry><EllipseGeometry Center="750,300" RadiusX="160" RadiusY="140"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A190A"><GeometryDrawing.Geometry><EllipseGeometry Center="50,420"  RadiusX="110" RadiusY="130"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="280,450" RadiusX="170" RadiusY="100"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#391909"><GeometryDrawing.Geometry><EllipseGeometry Center="560,480" RadiusX="150" RadiusY="120"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="840,430" RadiusX="90"  RadiusY="160"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="400,560" RadiusX="220" RadiusY="80"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="700,560" RadiusX="130" RadiusY="90"/></GeometryDrawing.Geometry></GeometryDrawing>
                <!-- A few smaller accent drips -->
                <GeometryDrawing Brush="#381809"><GeometryDrawing.Geometry><EllipseGeometry Center="200,150" RadiusX="55"  RadiusY="40"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1A0A"><GeometryDrawing.Geometry><EllipseGeometry Center="680,200" RadiusX="60"  RadiusY="45"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#391909"><GeometryDrawing.Geometry><EllipseGeometry Center="500,350" RadiusX="50"  RadiusY="70"/></GeometryDrawing.Geometry></GeometryDrawing>
                <GeometryDrawing Brush="#3A1909"><GeometryDrawing.Geometry><EllipseGeometry Center="120,510" RadiusX="65"  RadiusY="45"/></GeometryDrawing.Geometry></GeometryDrawing>
                <!-- Soft blur layers over the blobs — cross-angled low-opacity gradients -->
                <GeometryDrawing Geometry="M0,0 H900 V600 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1" Opacity="0.30">
                            <GradientStop Color="#3A1A0A" Offset="0.0"/>
                            <GradientStop Color="#391808" Offset="0.4"/>
                            <GradientStop Color="#3B1B0B" Offset="0.7"/>
                            <GradientStop Color="#3A1909" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H900 V600 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.20">
                            <GradientStop Color="#3B1B0B" Offset="0.0"/>
                            <GradientStop Color="#391808" Offset="0.5"/>
                            <GradientStop Color="#3A1A0A" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
                <GeometryDrawing Geometry="M0,0 H900 V600 H0 Z">
                    <GeometryDrawing.Brush>
                        <LinearGradientBrush StartPoint="0.2,1" EndPoint="0.8,0" Opacity="0.15">
                            <GradientStop Color="#391909" Offset="0.0"/>
                            <GradientStop Color="#3A1A0A" Offset="0.5"/>
                            <GradientStop Color="#381808" Offset="1.0"/>
                        </LinearGradientBrush>
                    </GeometryDrawing.Brush>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- Title text uses RedBrush — override to gold in Classic -->
    <SolidColorBrush x:Key="RedBrush"          Color="#C8900A"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"   Color="{StaticResource ShadowSurfaceAlt}"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="{StaticResource ShadowBorder}"/>
    <SolidColorBrush x:Key="RedHoverBrush"     Color="{StaticResource ShadowRedHover}"/>
    <SolidColorBrush x:Key="RedPressBrush"     Color="{StaticResource ShadowRedPress}"/>
    <SolidColorBrush x:Key="TextBrush"         Color="{StaticResource ShadowText}"/>
    <SolidColorBrush x:Key="TextMutedBrush"    Color="{StaticResource ShadowTextMuted}"/>
    <SolidColorBrush x:Key="BetaBadgeBrush" Color="#F5C842"/>
    <SolidColorBrush x:Key="GoldBrush"         Color="#C8900A"/>
    <!-- Used for highlighted/selected foreground in menus and dropdowns instead of gold,
         which becomes unreadable against light selection backgrounds. -->
    <SolidColorBrush x:Key="HighlightFgBrush"  Color="#1A3A5C"/>

    <!-- ═══════ Theme contract (consumed by BaseTheme.xaml) ═══════ -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#0E1B30"/>

    <SolidColorBrush x:Key="ButtonBgBrush" Color="#4A2210"/>
    <SolidColorBrush x:Key="ButtonFgBrush" Color="#C8900A"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ShadowRedHover}"/>
    <SolidColorBrush x:Key="ButtonPressBrush" Color="{StaticResource ShadowRedPress}"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#C8900A"/>
    <Thickness x:Key="ButtonBorderThickness">1</Thickness>
    <SolidColorBrush x:Key="ButtonDisabledBgBrush" Color="#4A3A20"/>
    <SolidColorBrush x:Key="ButtonDisabledFgBrush" Color="#7A6030"/>
    <Color x:Key="ButtonGlowColor">#D4A017</Color>
    <sys:Double x:Key="ButtonGlowBlur">8</sys:Double>
    <sys:Double x:Key="ButtonGlowDepth">1</sys:Double>
    <sys:Double x:Key="ButtonGlowOpacity">0.4</sys:Double>

    <SolidColorBrush x:Key="IconFgBrush" Color="#C8900A"/>
    <SolidColorBrush x:Key="IconHoverBrush" Color="#3A2A10"/>
    <SolidColorBrush x:Key="ArrowFillBrush" Color="#D4A017"/>
    <SolidColorBrush x:Key="CaretBrush" Color="#C8900A"/>

    <SolidColorBrush x:Key="AltSurfaceBrush" Color="{StaticResource ShadowSurfaceAlt}"/>
    <SolidColorBrush x:Key="RowSelectedBgBrush" Color="#55C8900A"/>
    <SolidColorBrush x:Key="RowSelectedFgBrush" Color="#1A3A5C"/>

    <SolidColorBrush x:Key="ListSelectedFgBrush" Color="#C8900A"/>
    <SolidColorBrush x:Key="SelectedFgBrush" Color="#1A3A5C"/>

    <SolidColorBrush x:Key="TrackBrush" Color="#1A0D04"/>
    <SolidColorBrush x:Key="ThumbBrush" Color="#C8900A"/>
    <SolidColorBrush x:Key="ThumbHoverBrush" Color="{StaticResource ShadowRedHover}"/>

    <!-- ═══════ Launch Button — purple vortex style (unique to Classic) ═══════ -->
    <Style x:Key="LaunchButton" TargetType="Button">
        <Setter Property="Background" Value="#5B2D8E"/>
        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5"
                            TextElement.FontFamily="{DynamicResource EmojiFont}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <Border.Effect>
                            <DropShadowEffect Color="#7B3DBE" BlurRadius="10" ShadowDepth="1" Opacity="0.5"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#7040AA"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#3A1A6A"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#2E1A50"/>
                            <Setter Property="Foreground" Value="#7A6030"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Grid Action Button — flat gold-on-blue (unique to Classic) ═══════ -->
    <Style x:Key="GridActionButton" TargetType="Button">
        <Setter Property="Background" Value="#0E1B30"/>
        <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource FantasyFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}"
                            TextElement.Foreground="{TemplateBinding Foreground}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource RedHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource RedPressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="BaseTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
