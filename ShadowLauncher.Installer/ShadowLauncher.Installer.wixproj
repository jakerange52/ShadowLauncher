<Project Sdk="WixToolset.Sdk/5.0.2">

  <PropertyGroup>
    <OutputName>ShadowLauncher-Setup</OutputName>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x86</InstallerPlatform>
    <Version>0.2.2</Version>
  </PropertyGroup>

  <PropertyGroup>
    <AppPublishDir Condition="''$(AppPublishDir)'' == ''">$(MSBuildThisFileDirectory)..\ShadowLauncher\bin\Release\net10.0-windows\</AppPublishDir>
    <CustomActionsDir Condition="''$(CustomActionsDir)'' == ''">$(MSBuildThisFileDirectory)..\ShadowLauncher.Installer.CustomActions\bin\Release\net10.0-windows\</CustomActionsDir>
    <ThirdPartyDir Condition="''$(ThirdPartyDir)'' == ''">$(MSBuildThisFileDirectory)ThirdParty\</ThirdPartyDir>
  </PropertyGroup>

  <ItemGroup>
    <WixExtension Include="WixToolset.UI.wixext" />
    <WixExtension Include="WixToolset.Util.wixext" />
    <WixExtension Include="WixToolset.Netfx.wixext" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Package.wxs" />
    <Compile Include="Privileges.wxs" />
    <Compile Include="ExitDialog.wxs" />
  </ItemGroup>

  <ItemGroup>
    <WixDefine Include="AppPublishDir=$(AppPublishDir)" />
    <WixDefine Include="CustomActionsDir=$(CustomActionsDir)" />
    <WixDefine Include="ThirdPartyDir=$(ThirdPartyDir)" />
  </ItemGroup>

</Project>

