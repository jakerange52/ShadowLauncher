<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="ShadowLauncher"
           Manufacturer="ShadowLauncher"
           Version="0.1.0"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           Codepage="1252"
           Compressed="yes">

    <!--
      Allow clean upgrades: remove the old version before installing the new one.
      DetectOnly prevents a downgrade from overwriting a newer install.
    -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of ShadowLauncher is already installed."
                  Schedule="afterInstallInitialize" />

    <!-- Standard WiX install UI (Welcome → Directory → Progress → Finish) -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- ── Directory structure ─────────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="ShadowLauncher" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="ShadowLauncher" />
    </StandardDirectory>

    <!--
      LocalAppData directory reference — needed so RemoveFolderEx can target
      %LOCALAPPDATA%\ShadowLauncher on uninstall.
    -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ShadowLauncherAppDataDir" Name="ShadowLauncher" />
    </StandardDirectory>

    <!-- Main application components -->
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">

      <!-- Primary executable -->
      <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="ShadowLauncherExe"
              Source="$(var.AppPublishDir)ShadowLauncher.exe"
              KeyPath="yes" />
      </Component>

      <!-- Main app DLL -->
      <Component Id="MainDll" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <File Source="$(var.AppPublishDir)ShadowLauncher.dll" KeyPath="yes" />
      </Component>

      <!-- Runtime config files -->
      <Component Id="DepsJson" Guid="D4E5F6A7-B8C9-0123-DEF0-234567890123">
        <File Source="$(var.AppPublishDir)ShadowLauncher.deps.json" KeyPath="yes" />
      </Component>

      <Component Id="RuntimeConfigJson" Guid="E5F6A7B8-C9D0-1234-EF01-345678901234">
        <File Source="$(var.AppPublishDir)ShadowLauncher.runtimeconfig.json" KeyPath="yes" />
      </Component>

      <!-- injector.dll (native, must ship alongside) -->
      <Component Id="InjectorDll" Guid="F6A7B8C9-D0E1-2345-F012-456789012345">
        <File Source="$(var.AppPublishDir)injector.dll" KeyPath="yes" />
      </Component>

      <!-- Microsoft.Extensions.* managed dependencies -->
      <Component Id="ExtDI" Guid="A7B8C9D0-E1F2-3456-0123-567890123456">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.DependencyInjection.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtDIAbs" Guid="B8C9D0E1-F2A3-4567-1234-678901234567">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.DependencyInjection.Abstractions.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtLogging" Guid="C9D0E1F2-A3B4-5678-2345-789012345678">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Logging.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtLoggingAbs" Guid="D0E1F2A3-B4C5-6789-3456-890123456789">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Logging.Abstractions.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtLoggingConsole" Guid="E1F2A3B4-C5D6-7890-4567-901234567890">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Logging.Console.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtLoggingConfig" Guid="F2A3B4C5-D6E7-8901-5678-012345678901">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Logging.Configuration.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtOptions" Guid="A3B4C5D6-E7F8-9012-6789-123456789012">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Options.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtOptionsConfigExt" Guid="B4C5D6E7-F8A9-0123-789A-234567890123">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Options.ConfigurationExtensions.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtConfig" Guid="C5D6E7F8-A9B0-1234-89AB-345678901234">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Configuration.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtConfigAbs" Guid="D6E7F8A9-B0C1-2345-9ABC-456789012345">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Configuration.Abstractions.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtConfigBinder" Guid="E7F8A9B0-C1D2-3456-ABCD-567890123456">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Configuration.Binder.dll" KeyPath="yes" />
      </Component>
      <Component Id="ExtPrimitives" Guid="F8A9B0C1-D2E3-4567-BCDE-678901234567">
        <File Source="$(var.AppPublishDir)Microsoft.Extensions.Primitives.dll" KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <!--
      Cleanup component — on uninstall, recursively removes
      %LOCALAPPDATA%\ShadowLauncher (DAT cache, settings, logs).
      On="uninstall" means it runs during both clean uninstall and major upgrade.
    -->
    <ComponentGroup Id="CleanupComponents" Directory="ShadowLauncherAppDataDir">
      <Component Id="AppDataCleanup" Guid="A1C2E3F4-B5D6-7890-EF12-345678901234">
        <util:RemoveFolderEx Id="RemoveAppDataFolder"
                             On="uninstall"
                             Property="LOCALAPPDATAPATH" />
        <RegistryValue Root="HKCU"
                       Key="Software\ShadowLauncher"
                       Name="AppDataCleanupInstalled"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Start Menu shortcut ─────────────────────────────────────────── -->
    <ComponentGroup Id="ShortcutComponents" Directory="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="A9B0C1D2-E3F4-5678-CDEF-789012345678">
        <Shortcut Id="StartMenuShortcut"
                  Name="ShadowLauncher"
                  Description="AC Multi-boxing Launcher"
                  Target="[INSTALLFOLDER]ShadowLauncher.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupStartMenu" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\ShadowLauncher"
                       Name="StartMenuShortcutInstalled"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Feature tree ────────────────────────────────────────────────── -->
    <!--
      Resolve %LOCALAPPDATA% at install time into LOCALAPPDATAPATH so
      RemoveFolderEx knows where to clean up on uninstall.
    -->
    <Property Id="LOCALAPPDATAPATH">
      <RegistrySearch Id="LocalAppDataSearch" Root="HKCU"
                      Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Shell Folders"
                      Name="Local AppData" Type="raw" />
    </Property>

    <Feature Id="MainFeature" Title="ShadowLauncher" Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentGroupRef Id="CleanupComponents" />
    </Feature>

  </Package>
</Wix>
