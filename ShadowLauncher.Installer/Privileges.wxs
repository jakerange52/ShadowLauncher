<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>

    <Binary Id="CustomActionsDll"
            SourceFile="$(var.CustomActionsDir)ShadowLauncher.Installer.CustomActions.dll" />

    <!--
      SHOWLOGOFFMESSAGE / symlink privilege actions commented out — hard links no longer
      require SeCreateSymbolicLinkPrivilege. Re-enable if reverting to SymlinkLauncher.

    <Property Id="SHOWLOGOFFMESSAGE" Secure="yes" />

    <CustomAction Id="CheckSymlinkPrivilege"
                  BinaryRef="CustomActionsDll"
                  DllEntry="CheckSymlinkPrivilege"
                  Execute="immediate"
                  Return="ignore" />

    <CustomAction Id="GrantSymlinkPrivilege"
                  BinaryRef="CustomActionsDll"
                  DllEntry="GrantSymlinkPrivilege"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />
    -->

    <!--
      Deletes %LOCALAPPDATA%\ShadowLauncher on uninstall.
      Impersonate="yes" so it runs as the installing user and resolves the correct LocalAppData.
      Return="ignore" so a failure never blocks the uninstall.
    -->
    <CustomAction Id="CleanupAppData"
                  BinaryRef="CustomActionsDll"
                  DllEntry="CleanupAppData"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallUISequence>
      <!--
      <Custom Action="CheckSymlinkPrivilege"
              After="CostFinalize"
              Condition="NOT REMOVE~=&quot;ALL&quot;" />
      --><!-- symlink -->
    </InstallUISequence>

    <InstallExecuteSequence>
      <!--
      <Custom Action="CheckSymlinkPrivilege"
              Before="GrantSymlinkPrivilege"
              Condition="NOT REMOVE~=&quot;ALL&quot;" />
      <Custom Action="GrantSymlinkPrivilege"
               After="InstallFiles"
               Condition="NOT REMOVE~=&quot;ALL&quot;" />
      --><!-- symlink -->
      <!-- CleanupAppData must NOT run during upgrades (MajorUpgrade sets REMOVE=ALL
           on the old product even though a new version is about to be installed).
           UPGRADINGPRODUCTCODE is set on the old product during an upgrade sequence,
           so we guard against it here to preserve user settings and data. -->
      <Custom Action="CleanupAppData"
               After="RemoveFiles"
               Condition="REMOVE~=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

  </Fragment>

</Wix>
