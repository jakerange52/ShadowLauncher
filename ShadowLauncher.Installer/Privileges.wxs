<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>

    <Binary Id="CustomActionsDll"
            SourceFile="$(var.CustomActionsDir)ShadowLauncher.Installer.CustomActions.dll" />

    <CustomAction Id="CleanupAppData"
                  BinaryRef="CustomActionsDll"
                  DllEntry="CleanupAppData"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <CustomAction Id="InstallShadowFilterDecalPlugin"
                  BinaryRef="CustomActionsDll"
                  DllEntry="InstallShadowFilterDecalPlugin"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <CustomAction Id="UninstallShadowFilterDecalPlugin"
                  BinaryRef="CustomActionsDll"
                  DllEntry="UninstallShadowFilterDecalPlugin"
                  Execute="deferred"
                  Impersonate="yes"
                  Return="ignore" />

    <SetProperty Id="InstallShadowFilterDecalPlugin"
                 Value="SOURCE_DIR=[INSTALLFOLDER]ShadowFilter\"
                 Before="InstallShadowFilterDecalPlugin"
                 Sequence="execute"
                 Condition="&amp;MultiboxingFeature=3 AND NOT REMOVE" />

    <InstallUISequence>
    </InstallUISequence>

    <InstallExecuteSequence>
      <Custom Action="CleanupAppData"
               After="RemoveFiles"
               Condition="REMOVE~=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="InstallShadowFilterDecalPlugin"
               After="InstallFiles"
               Condition="&amp;MultiboxingFeature=3 AND NOT REMOVE" />
      <Custom Action="UninstallShadowFilterDecalPlugin"
               Before="RemoveFiles"
               Condition="REMOVE~=&quot;ALL&quot; AND (&amp;MultiboxingFeature=3 OR SHADOWFILTERINSTALLED)" />
    </InstallExecuteSequence>

  </Fragment>

</Wix>
